# ==========================================
# Butterfly Blog - 环境变量模板
# 复制此文件为 .env 并填写实际值
# ==========================================

# 服务器地址（开发环境）
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# PostgreSQL 数据库连接（必须修改）
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/butterfly_blog

# Payload 加密密钥（必须生成新的随机值）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=CHANGE_ME_TO_RANDOM_STRING

# NextAuth 配置
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_TO_RANDOM_STRING

# GitHub OAuth（可选）
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
